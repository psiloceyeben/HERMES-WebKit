#!/usr/bin/env bash
# HERMES — command-line interface

THEME_FILE="/root/hermes/.hermes_theme.json"

BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[0;33m'

# ── resolve which site to talk to ─────────────────────────────────────────────
# hermes chat          → main site
# hermes chat myblog   → vessels/myblog
# HERMES_ENV=...       → explicit env override
_resolve_site() {
  local name="${1:-}"
  if [[ -n "$name" && "$name" != "main" ]]; then
    _ENV_FILE="/root/hermes/vessels/$name/.env"
    if [[ ! -f "$_ENV_FILE" ]]; then
      echo -e "\n  ${RED}error:${RESET} site '$name' not found — run: hermes sites\n"
      exit 1
    fi
    _SITE_LABEL="$name"
  else
    _ENV_FILE="${HERMES_ENV:-/root/hermes/.env}"
    _SITE_LABEL="main"
  fi

  BUILD_TOKEN=$(python3 -c "
import re, os
env = '$_ENV_FILE'
if os.path.exists(env):
    for line in open(env):
        m = re.match(r'BUILD_TOKEN=(.+)', line.strip())
        if m: print(m.group(1).strip('\"').strip(\"'\")); break
" 2>/dev/null)

  if [[ -z "$BUILD_TOKEN" ]]; then
    echo -e "\n  ${RED}error:${RESET} BUILD_TOKEN not set in $_ENV_FILE"
    echo -e "  Add BUILD_TOKEN=your-secret-token to .env and run: hermes restart\n"
    exit 1
  fi

  _PORT=$(python3 -c "
import re, os
env = '$_ENV_FILE'
if os.path.exists(env):
    for line in open(env):
        m = re.match(r'HERMES_PORT=(.+)', line.strip())
        if m: print(m.group(1).strip()); break
" 2>/dev/null)
  _PORT="${_PORT:-8000}"
  BRIDGE="http://127.0.0.1:$_PORT"
}

# Default: resolve main site immediately (commands that don't take a site name)
_resolve_site ""

color_code() {
  case "$1" in
    red)     echo '\033[0;31m' ;;
    green)   echo '\033[0;32m' ;;
    yellow)  echo '\033[0;33m' ;;
    blue)    echo '\033[0;34m' ;;
    magenta) echo '\033[0;35m' ;;
    white)   echo '\033[0;37m' ;;
    cyan|*)  echo '\033[0;36m' ;;
  esac
}

load_theme() {
  ACCENT_COLOR="cyan"
  VESSEL_LABEL="vessel"
  T_BANNER=""
  T_TAGLINE="vessel interface"
  T_INPUT_PROMPT=""
  T_YOU_OPEN=""
  T_YOU_CLOSE=""
  T_VESSEL_OPEN=""
  T_VESSEL_CLOSE=""
  T_DIVIDER=""
  if [[ -f "$THEME_FILE" ]]; then
    _py() { python3 -c "import json; d=json.load(open('$THEME_FILE')); print(d.get('$1',''))" 2>/dev/null; }
    ACCENT_COLOR=$(  _py accent);       [[ -z "$ACCENT_COLOR" ]] && ACCENT_COLOR="cyan"
    VESSEL_LABEL=$(  _py label);        [[ -z "$VESSEL_LABEL" ]] && VESSEL_LABEL="vessel"
    T_BANNER=$(      _py banner)
    T_TAGLINE=$(     _py tagline)
    T_INPUT_PROMPT=$(_py input_prompt)
    T_YOU_OPEN=$(    _py you_open)
    T_YOU_CLOSE=$(   _py you_close)
    T_VESSEL_OPEN=$( _py vessel_open)
    T_VESSEL_CLOSE=$(_py vessel_close)
    T_DIVIDER=$(     _py divider)
  fi
  ACCENT=$(color_code "$ACCENT_COLOR")
}

save_theme() {
  python3 - "$@" << 'PYEOF'
import json, sys
keys = ['accent','label','banner','tagline','input_prompt','you_open','you_close','vessel_open','vessel_close','divider']
d = {k: sys.argv[i+1] if i+1 < len(sys.argv) else '' for i, k in enumerate(keys)}
json.dump(d, open('/root/hermes/.hermes_theme.json','w'), indent=2)
PYEOF
}

banner() {
  load_theme
  echo ""
  if [[ -n "$T_BANNER" ]]; then
    echo -e "${ACCENT}$(echo -e "$T_BANNER")${RESET}"
  else
    echo -e "${ACCENT}  ██╗  ██╗███████╗██████╗ ███╗   ███╗███████╗███████╗${RESET}"
    echo -e "${ACCENT}  ██║  ██║██╔════╝██╔══██╗████╗ ████║██╔════╝██╔════╝${RESET}"
    echo -e "${ACCENT}  ███████║█████╗  ██████╔╝██╔████╔██║█████╗  ███████╗${RESET}"
    echo -e "${ACCENT}  ██╔══██║██╔══╝  ██╔══██╗██║╚██╔╝██║██╔══╝  ╚════██║${RESET}"
    echo -e "${ACCENT}  ██║  ██║███████╗██║  ██║██║ ╚═╝ ██║███████╗███████║${RESET}"
    echo -e "${ACCENT}  ╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝╚═╝     ╚═╝╚══════╝╚══════╝${RESET}"
  fi
  echo ""
  echo -e "  ${DIM}${T_TAGLINE:-vessel interface}${RESET}"
  echo ""
}

print_vessel() {
  if [[ -n "$T_VESSEL_OPEN" ]]; then
    echo -e "${ACCENT}${T_VESSEL_OPEN}${RESET} $1"
    [[ -n "$T_VESSEL_CLOSE" ]] && echo -e "${ACCENT}${T_VESSEL_CLOSE}${RESET}"
  else
    echo -e "  ${ACCENT}${VESSEL_LABEL}:${RESET} $1"
  fi
}

print_divider() {
  [[ -n "$T_DIVIDER" ]] && echo -e "  ${DIM}${T_DIVIDER}${RESET}"
  echo ""
}

handle_response() {
  local raw="$1"
  local session_id="$2"

  local kind
  kind=$(echo "$raw" | python3 -c "
import json,sys
d=json.load(sys.stdin)
if 'reply' in d:    print('reply')
elif d.get('pending'): print('pending')
elif 'error' in d: print('error')
else: print('unknown')
" 2>/dev/null)

  if [[ "$kind" == "reply" ]]; then
    local reply
    reply=$(echo "$raw" | python3 -c "import json,sys; print(json.load(sys.stdin)['reply'])" 2>/dev/null)

    local new_accent
    new_accent=$(echo "$raw" | python3 -c "import json,sys; d=json.load(sys.stdin); t=d.get('theme',{}); print(t.get('accent',''))" 2>/dev/null)
    if [[ -n "$new_accent" ]]; then
      local new_label new_banner new_tagline new_input new_you_open new_you_close new_vessel_open new_vessel_close new_divider
      new_label=$(      echo "$raw" | python3 -c "import json,sys; t=json.load(sys.stdin).get('theme',{}); print(t.get('label',''))"        2>/dev/null)
      new_banner=$(     echo "$raw" | python3 -c "import json,sys; t=json.load(sys.stdin).get('theme',{}); print(t.get('banner',''))"       2>/dev/null)
      new_tagline=$(    echo "$raw" | python3 -c "import json,sys; t=json.load(sys.stdin).get('theme',{}); print(t.get('tagline',''))"      2>/dev/null)
      new_input=$(      echo "$raw" | python3 -c "import json,sys; t=json.load(sys.stdin).get('theme',{}); print(t.get('input_prompt',''))" 2>/dev/null)
      new_you_open=$(   echo "$raw" | python3 -c "import json,sys; t=json.load(sys.stdin).get('theme',{}); print(t.get('you_open',''))"     2>/dev/null)
      new_you_close=$(  echo "$raw" | python3 -c "import json,sys; t=json.load(sys.stdin).get('theme',{}); print(t.get('you_close',''))"    2>/dev/null)
      new_vessel_open=$(echo "$raw" | python3 -c "import json,sys; t=json.load(sys.stdin).get('theme',{}); print(t.get('vessel_open',''))"  2>/dev/null)
      new_vessel_close=$(echo "$raw"| python3 -c "import json,sys; t=json.load(sys.stdin).get('theme',{}); print(t.get('vessel_close',''))" 2>/dev/null)
      new_divider=$(    echo "$raw" | python3 -c "import json,sys; t=json.load(sys.stdin).get('theme',{}); print(t.get('divider',''))"      2>/dev/null)
      ACCENT_COLOR="$new_accent"
      [[ -n "$new_label" ]] && VESSEL_LABEL="$new_label"
      T_BANNER="$new_banner"; T_TAGLINE="$new_tagline"; T_INPUT_PROMPT="$new_input"
      T_YOU_OPEN="$new_you_open"; T_YOU_CLOSE="$new_you_close"
      T_VESSEL_OPEN="$new_vessel_open"; T_VESSEL_CLOSE="$new_vessel_close"
      T_DIVIDER="$new_divider"
      ACCENT=$(color_code "$ACCENT_COLOR")
      save_theme "$ACCENT_COLOR" "$VESSEL_LABEL" "$T_BANNER" "$T_TAGLINE" \
                 "$T_INPUT_PROMPT" "$T_YOU_OPEN" "$T_YOU_CLOSE" \
                 "$T_VESSEL_OPEN" "$T_VESSEL_CLOSE" "$T_DIVIDER"
      echo ""
      echo -e "  ${DIM}— terminal restyled —${RESET}"
      echo ""
      banner
    fi

    echo ""
    print_vessel "$reply"
    echo ""
    print_divider

  elif [[ "$kind" == "pending" ]]; then
    local vessel_text
    vessel_text=$(echo "$raw" | python3 -c "
import json, sys
print(json.load(sys.stdin).get('vessel_text', ''))
" 2>/dev/null)
    if [[ -n "$vessel_text" ]]; then
      echo ""
      print_vessel "$vessel_text"
    fi

    echo ""
    echo "$raw" | python3 -c "
import json, sys
actions = json.load(sys.stdin).get('pending', [])
descs = [a.get('description','') for a in actions if a.get('description')]
if descs:
    for d in descs:
        print(f'  · {d}')
" 2>/dev/null
    echo ""

    printf "  ${ACCENT}${VESSEL_LABEL}:${RESET} shall I go ahead? "
    read -r confirm
    echo ""

    local confirmed
    confirmed=$(python3 -c "
import sys
msg = sys.argv[1].lower().strip()
yes_words = {'y','yes','yeah','yep','yup','sure','ok','okay','go','do it',
             'proceed','absolutely','sounds good','go ahead','definitely',
             'please','do that','make it so','lets go','let s go','affirmative'}
print('True' if any(w in msg for w in yes_words) else 'False')
" "$confirm" 2>/dev/null || echo "False")

    if [[ "$confirmed" == "True" ]]; then
      echo -e "  ${ACCENT}▸${RESET} ${DIM}working...${RESET}"
      echo ""
    else
      echo -e "  ${ACCENT}${VESSEL_LABEL}:${RESET} alright, leaving it as is."
      echo ""
    fi

    local confirm_payload
    confirm_payload=$(python3 -c "
import json
print(json.dumps({'session_id': '$session_id', 'confirmed': $confirmed}))
" 2>/dev/null)

    local confirm_raw
    confirm_raw=$(curl -s -X POST "$BRIDGE/chat/confirm" \
      -H "Content-Type: application/json" \
      -H "X-Build-Token: $BUILD_TOKEN" \
      -d "$confirm_payload")

    handle_response "$confirm_raw" "$session_id"

  elif [[ "$kind" == "error" ]]; then
    local err
    err=$(echo "$raw" | python3 -c "import json,sys; print(json.load(sys.stdin).get('error','unknown error'))" 2>/dev/null)
    echo ""
    echo -e "  ${RED}error:${RESET} $err"
    echo ""
  else
    echo ""
    echo -e "  ${DIM}(no response)${RESET}"
    echo ""
  fi
}

# ── inline setup wizard — used by 'new' and 'new-site' ────────────────────────
run_wizard() {
  local vessel_dir="$1"
  local port="$2"
  local token="$3"

  echo -e "  ${DIM}answer a few questions to define the vessel${RESET}"
  echo ""

  printf "  what is this website called?                    "
  read -r W_NAME
  printf "  what is it for, and who is it for?              "
  read -r W_PURPOSE
  printf "  what voice or tone?                             "
  read -r W_VOICE
  printf "  what does it know about?                        "
  read -r W_KNOWS
  printf "  what should visitors feel or do when they leave? "
  read -r W_OUTCOME
  printf "  what makes this specific to you?                "
  read -r W_SPECIFIC
  printf "  what should it never do or say?                 "
  read -r W_NEVER
  printf "  your name or contact (optional)                 "
  read -r W_CONTACT

  echo ""

  # Write VESSEL.md
  mkdir -p "$vessel_dir"
  cat > "$vessel_dir/VESSEL.md" << VESSELEOF
# $W_NAME

## Purpose
$W_PURPOSE

## Voice and tone
$W_VOICE

## Knowledge
$W_KNOWS

## Visitor outcome
$W_OUTCOME

## What makes this specific
$W_SPECIFIC

## Constraints
$W_NEVER

## Contact
$W_CONTACT
VESSELEOF

  echo -e "  ${ACCENT}▸${RESET} ${DIM}building first page...${RESET}"
  sleep 2  # let bridge settle if just started
  curl -s -X POST "http://127.0.0.1:$port/build" \
    -H "X-Build-Token: $token" \
    -d "render the site homepage" > /dev/null
  echo -e "  ${GREEN}✓${RESET} vessel configured and site built"
  echo ""
}

# ── commands ───────────────────────────────────────────────────────────────────
CMD="${1:-}"

case "$CMD" in

  chat)
    _resolve_site "${2:-}"
    load_theme
    banner
    SESSION_ID=$(python3 -c "import uuid; print(str(uuid.uuid4())[:8])")
    echo -e "  ${ACCENT}▸${RESET} ${VESSEL_LABEL} is listening  ${DIM}$_SITE_LABEL · session: $SESSION_ID${RESET}"
    echo -e "  ${DIM}ask anything · ask to build features · ask to restyle · type exit to leave${RESET}"
    echo ""

    while true; do
      if [[ -n "$T_INPUT_PROMPT" ]]; then
        printf "  ${ACCENT}${T_INPUT_PROMPT}${RESET}"
      else
        printf "  ${BOLD}you:${RESET} "
      fi
      read -r msg
      [[ -z "$msg" ]] && continue
      [[ "${msg,,}" == "exit" || "${msg,,}" == "quit" ]] && echo "" && break

      payload=$(python3 -c "
import json, sys
print(json.dumps({'message': sys.argv[1], 'session_id': sys.argv[2]}))
" "$msg" "$SESSION_ID" 2>/dev/null)

      raw=$(curl -s -X POST "$BRIDGE/chat" \
        -H "Content-Type: application/json" \
        -H "X-Build-Token: $BUILD_TOKEN" \
        -d "$payload")

      handle_response "$raw" "$SESSION_ID"
    done
    ;;

  studio)
    # Open a tmux studio: chat (left), shell (top-right), live logs (bottom-right).
    # Status bar shows service health + build count, refreshes every 30s.
    # Click between panes with the mouse.
    # hermes studio          → main site
    # hermes studio myblog   → specific vessel
    SITE_ARG="${2:-}"
    SESSION="hermes${SITE_ARG:+-$SITE_ARG}"

    if ! command -v tmux &>/dev/null; then
      echo -e "\n  installing tmux..."
      apt-get install -y tmux -qq
    fi

    TMUX_CONF="/root/hermes/.hermes_tmux.conf"
    STATUS_SCRIPT="/root/hermes/.hermes_status.sh"

    # Status bar script — called by tmux every 30s
    cat > "$STATUS_SCRIPT" << 'STATUSEOF'
#!/bin/bash
ENV_FILE="/root/hermes/.env"
TOKEN=$(python3 -c "
import re, os
if os.path.exists('$ENV_FILE'):
    for line in open('$ENV_FILE'):
        m = re.match(r'BUILD_TOKEN=(.+)', line.strip())
        if m: print(m.group(1).strip('\"').strip(\"'\")); break
" 2>/dev/null)
RESULT=$(curl -s --max-time 2 -H "X-Build-Token: $TOKEN" http://127.0.0.1:8000/analytics 2>/dev/null)
BUILDS=$(echo "$RESULT" | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d.get('total', '?'))
except: print('?')
" 2>/dev/null)
STATUS=$(systemctl is-active hermes 2>/dev/null)
[ "$STATUS" = "active" ] && DOT="●" || DOT="○"
echo " $DOT ${BUILDS:-?} builds  Ctrl+A D to detach "
STATUSEOF
    chmod +x "$STATUS_SCRIPT"

    # Tmux config: mouse on, Ctrl+A prefix, status bar with live script
    cat > "$TMUX_CONF" << 'TMUXEOF'
set -g mouse on
set -g prefix C-a
unbind C-b
bind C-a send-prefix
set -g status-interval 30
set -g status-style 'bg=#1a1a1a fg=#666666'
set -g status-left ' hermes  '
set -g status-right '#(/root/hermes/.hermes_status.sh)'
set -g status-left-length 20
set -g status-right-length 60
set -g pane-border-style 'fg=#333333'
set -g pane-active-border-style 'fg=#666666'
set -g base-index 1
setw -g mode-keys vi
TMUXEOF

    # Always recreate for a clean layout
    tmux kill-session -t "$SESSION" 2>/dev/null || true

    LOG_SVC="hermes${SITE_ARG:+-$SITE_ARG}"
    tmux -f "$TMUX_CONF" new-session -d -s "$SESSION"
    # Left pane (60%): operator chat
    tmux -f "$TMUX_CONF" send-keys -t "$SESSION" "hermes chat $SITE_ARG" Enter
    # Split right (40%): shell
    tmux -f "$TMUX_CONF" split-window -t "$SESSION" -h -p 40
    tmux -f "$TMUX_CONF" send-keys -t "$SESSION" "hermes sites" Enter
    # Split bottom-right (35% of right): live logs
    tmux -f "$TMUX_CONF" split-window -t "$SESSION" -v -p 35
    tmux -f "$TMUX_CONF" send-keys -t "$SESSION" "journalctl -u $LOG_SVC -f --no-pager -n 10" Enter
    # Focus back to chat
    tmux -f "$TMUX_CONF" select-pane -t "$SESSION" -L
    tmux -f "$TMUX_CONF" attach-session -t "$SESSION"
    ;;

  theme)
    load_theme; banner
    echo -e "  ${BOLD}current theme:${RESET}"
    echo ""
    echo -e "  accent        ${ACCENT}$ACCENT_COLOR${RESET}"
    echo -e "  label         $VESSEL_LABEL"
    [[ -n "$T_TAGLINE" ]]      && echo -e "  tagline       ${DIM}$T_TAGLINE${RESET}"
    [[ -n "$T_INPUT_PROMPT" ]] && echo -e "  input prompt  ${DIM}$T_INPUT_PROMPT${RESET}"
    [[ -n "$T_DIVIDER" ]]      && echo -e "  divider       ${DIM}$T_DIVIDER${RESET}"
    echo ""
    echo -e "  ${DIM}in chat, ask to restyle: 'make this look like a submarine'${RESET}"
    echo ""
    ;;

  theme-reset)
    rm -f "$THEME_FILE"
    echo -e "\n  theme reset to default\n"
    ;;

  status)
    SITE_NAME="${2:-}"
    banner
    if [[ -n "$SITE_NAME" && "$SITE_NAME" != "main" ]]; then
      systemctl status "hermes-$SITE_NAME" --no-pager
    else
      systemctl status hermes --no-pager
    fi
    ;;

  logs)
    SITE_NAME="${2:-}"
    banner
    echo -e "  ${DIM}streaming logs — ctrl+c to exit${RESET}\n"
    if [[ -n "$SITE_NAME" && "$SITE_NAME" != "main" ]]; then
      journalctl -u "hermes-$SITE_NAME" -f --no-pager
    else
      journalctl -u hermes -f --no-pager
    fi
    ;;

  build)
    banner
    MSG="${2:-render the site homepage}"
    echo -e "  ${ACCENT}▸${RESET} building: ${DIM}$MSG${RESET}\n"
    curl -s -X POST "$BRIDGE/build" \
      -H "X-Build-Token: $BUILD_TOKEN" \
      -d "$MSG"
    echo ""
    ;;

  restart)
    banner
    echo -e "  ${ACCENT}▸${RESET} restarting hermes..."
    systemctl restart hermes && sleep 2
    systemctl is-active --quiet hermes \
      && echo -e "  ${GREEN}✓${RESET} running" \
      || echo -e "  ${RED}!${RESET} failed to start"
    echo ""
    ;;

  sites)
    load_theme; banner
    echo -e "  ${BOLD}vessels on this server:${RESET}"
    echo ""
    IP=$(curl -s --max-time 3 ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}')

    # Main site
    MAIN_STATUS=$(systemctl is-active hermes 2>/dev/null)
    MAIN_COLOR=$([[ "$MAIN_STATUS" == "active" ]] && echo "$GREEN" || echo "$RED")
    MAIN_NAME=$(python3 -c "
import os
v = '/root/hermes/vessel/VESSEL.md'
if os.path.exists(v):
    for line in open(v):
        line = line.strip()
        if line.startswith('# '):
            print(line[2:]); break
" 2>/dev/null)
    MAIN_DOMAIN=$(grep -r "server_name" /etc/nginx/sites-enabled/hermes 2>/dev/null | awk '{print $2}' | tr -d ';' | grep -v '_' | head -1)
    MAIN_URL="${MAIN_DOMAIN:-$IP}"
    echo -e "  ${MAIN_COLOR}●${RESET}  ${BOLD}main${RESET}  ${DIM}port 8000${RESET}  —  ${ACCENT}http://$MAIN_URL${RESET}  ${DIM}${MAIN_NAME}${RESET}"

    # Additional sites
    for svc_file in /etc/systemd/system/hermes-*.service; do
      [[ -f "$svc_file" ]] || continue
      SNAME=$(basename "$svc_file" .service | sed 's/hermes-//')
      SSTATUS=$(systemctl is-active "hermes-$SNAME" 2>/dev/null)
      SCOLOR=$([[ "$SSTATUS" == "active" ]] && echo "$GREEN" || echo "$RED")
      SPORT=$(grep -E 'HERMES_PORT|--port' "$svc_file" 2>/dev/null | grep -o '[0-9]\{4,\}' | head -1)
      SDIR=$(grep EnvironmentFile "$svc_file" 2>/dev/null | awk '{print $2}' | xargs dirname 2>/dev/null)
      SVNAME=$(python3 -c "
import os
v = '$SDIR/vessel/VESSEL.md'
if os.path.exists(v):
    for line in open(v):
        line = line.strip()
        if line.startswith('# '):
            print(line[2:]); break
" 2>/dev/null)
      SDOMAIN=$(grep -r "server_name" "/etc/nginx/sites-enabled/$SNAME" 2>/dev/null | awk '{print $2}' | tr -d ';' | grep -v '_' | head -1)
      if [[ -n "$SDOMAIN" ]]; then
        SURL="http://$SDOMAIN"
      else
        SURL="http://$IP:${SPORT:-?}"
      fi
      echo -e "  ${SCOLOR}●${RESET}  ${BOLD}$SNAME${RESET}  ${DIM}port ${SPORT:-?}${RESET}  —  ${ACCENT}$SURL${RESET}  ${DIM}${SVNAME}${RESET}"
    done

    echo ""
    echo -e "  ${DIM}hermes new-site <name>            create a new vessel${RESET}"
    echo -e "  ${DIM}hermes add-domain <name> <domain> attach a domain to a vessel${RESET}"
    echo ""
    ;;

  new)
    load_theme; banner
    echo -e "  ${BOLD}rebuild vessel from scratch${RESET}"
    echo ""
    echo -e "  The current VESSEL.md and STATE.md will be archived."
    echo -e "  The setup wizard will run here in the terminal."
    echo ""
    echo -e "  ${RED}this replaces the current vessel identity${RESET}"
    echo ""
    printf "  type ${BOLD}yes${RESET} to confirm: "
    read -r confirm
    echo ""
    if [[ "$confirm" != "yes" ]]; then
      echo -e "  ${ACCENT}${VESSEL_LABEL}:${RESET} cancelled — nothing changed."
      echo ""
      exit 0
    fi

    BACKUP="/root/hermes/vessel_archive_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$BACKUP"
    [[ -f /root/hermes/vessel/VESSEL.md ]] && cp /root/hermes/vessel/VESSEL.md "$BACKUP/"
    [[ -f /root/hermes/vessel/STATE.md  ]] && cp /root/hermes/vessel/STATE.md  "$BACKUP/"
    rm -f /root/hermes/vessel/VESSEL.md /root/hermes/vessel/STATE.md
    echo -e "  ${GREEN}✓${RESET} archived to $BACKUP"
    echo ""

    run_wizard "/root/hermes/vessel" "8000" "$BUILD_TOKEN"

    systemctl restart hermes
    IP=$(curl -s --max-time 3 ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}')
    echo -e "  ${ACCENT}▸${RESET} live at http://$IP"
    echo ""
    ;;

  new-site)
    load_theme; banner
    SITE_NAME="${2:-}"
    if [[ -z "$SITE_NAME" ]]; then
      echo -e "  ${BOLD}usage:${RESET} hermes new-site <name> [domain]"
      echo -e "  ${DIM}example: hermes new-site myblog${RESET}"
      echo -e "  ${DIM}example: hermes new-site myblog myblog.com${RESET}"
      echo ""
      exit 1
    fi

    # Find next available port
    PORT=8001
    while ss -tlnp | grep -q ":$PORT "; do
      PORT=$((PORT + 1))
    done

    SITE_DIR="/root/hermes/vessels/$SITE_NAME"
    SERVICE="hermes-$SITE_NAME"
    ENV_FILE="$SITE_DIR/.env"
    DOMAIN="${3:-}"

    echo -e "  ${BOLD}new vessel:${RESET} $SITE_NAME  ${DIM}(port $PORT)${RESET}"
    [[ -n "$DOMAIN" ]] && echo -e "  ${BOLD}domain:${RESET}     $DOMAIN"
    echo ""

    # Scaffold directories and copy tree nodes
    mkdir -p "$SITE_DIR/vessel/tree" "$SITE_DIR/static"
    cp -r /root/hermes/vessel/tree/. "$SITE_DIR/vessel/tree/"
    cp /root/hermes/vessel/HECATE.md "$SITE_DIR/vessel/" 2>/dev/null || true

    # Write .env
    ORIG_KEY=$(python3 -c "
import re
for line in open('/root/hermes/.env'):
    m = re.match(r'ANTHROPIC_API_KEY=(.+)', line.strip())
    if m: print(m.group(1).strip('\"').strip(\"'\")); break
" 2>/dev/null)
    ORIG_MODEL=$(python3 -c "
import re
for line in open('/root/hermes/.env'):
    m = re.match(r'HERMES_MODEL=(.+)', line.strip())
    if m: print(m.group(1).strip('\"').strip(\"'\")); break
" 2>/dev/null)
    NEW_TOKEN=$(python3 -c "import secrets; print(secrets.token_hex(32))")

    cat > "$ENV_FILE" << ENVEOF
ANTHROPIC_API_KEY=$ORIG_KEY
HERMES_MODEL=${ORIG_MODEL:-claude-sonnet-4-6}
VESSEL_DIR=$SITE_DIR/vessel
STATIC_DIR=$SITE_DIR/static
BUILD_TOKEN=$NEW_TOKEN
HERMES_PORT=$PORT
ENVEOF

    # Write systemd service
    cat > "/etc/systemd/system/$SERVICE.service" << SVCEOF
[Unit]
Description=HERMES vessel — $SITE_NAME
After=network.target

[Service]
User=root
WorkingDirectory=/root/hermes
ExecStart=/usr/bin/python3 /root/hermes/bridge.py
Restart=always
RestartSec=5
EnvironmentFile=$ENV_FILE

[Install]
WantedBy=multi-user.target
SVCEOF

    systemctl daemon-reload
    systemctl enable "$SERVICE" --quiet
    systemctl start "$SERVICE"

    # Run inline wizard
    run_wizard "$SITE_DIR/vessel" "$PORT" "$NEW_TOKEN"

    systemctl is-active --quiet "$SERVICE" \
      && echo -e "  ${GREEN}✓${RESET} $SITE_NAME is running" \
      || echo -e "  ${RED}!${RESET} $SERVICE failed — check: journalctl -u $SERVICE -n 30"

    # nginx block
    if [[ -n "$DOMAIN" ]]; then
      cat > "/etc/nginx/sites-enabled/$SITE_NAME" << NGEOF
server {
    listen 80;
    server_name $DOMAIN www.$DOMAIN;
    root $SITE_DIR/static;
    index index.html;
    location ~ ^/(chat|chat/confirm) { allow 127.0.0.1; allow ::1; deny all; }
    location ~ ^/(health|build|setup|ask|agent|agents|analytics) {
        proxy_pass http://127.0.0.1:$PORT;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_read_timeout 120s;
    }
    location / { try_files \$uri \$uri/ \$uri/index.html @bridge; }
    location @bridge {
        proxy_pass http://127.0.0.1:$PORT;
        proxy_set_header Host \$host;
        proxy_read_timeout 120s;
    }
}
NGEOF
      nginx -t && systemctl reload nginx
      IP=$(curl -s --max-time 3 ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}')
      echo -e "  ${GREEN}✓${RESET} nginx configured for $DOMAIN"
      echo ""
      echo -e "  ${ACCENT}▸${RESET} live at http://$DOMAIN  ${DIM}(point DNS A record → $IP)${RESET}"
      echo -e "  ${DIM}  then: certbot --nginx -d $DOMAIN -d www.$DOMAIN${RESET}"
    else
      IP=$(curl -s --max-time 3 ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}')
      echo -e "  ${ACCENT}▸${RESET} live at http://$IP:$PORT"
      echo -e "  ${DIM}  add a domain: hermes add-domain $SITE_NAME yourdomain.com${RESET}"
    fi
    echo -e "  ${DIM}  build token: $NEW_TOKEN${RESET}"
    echo ""
    ;;

  add-domain)
    load_theme; banner
    SITE_NAME="${2:-}"
    DOMAIN="${3:-}"
    if [[ -z "$SITE_NAME" || -z "$DOMAIN" ]]; then
      echo -e "  ${BOLD}usage:${RESET} hermes add-domain <site-name> <domain>"
      echo -e "  ${DIM}example: hermes add-domain myblog myblog.com${RESET}"
      echo ""
      exit 1
    fi
    SERVICE="hermes-$SITE_NAME"
    SITE_DIR="/root/hermes/vessels/$SITE_NAME"
    PORT=$(grep HERMES_PORT "$SITE_DIR/.env" 2>/dev/null | cut -d= -f2)
    if [[ -z "$PORT" ]]; then
      echo -e "  ${RED}error:${RESET} site '$SITE_NAME' not found or port unknown"
      exit 1
    fi
    cat > "/etc/nginx/sites-enabled/$SITE_NAME" << NGEOF
server {
    listen 80;
    server_name $DOMAIN www.$DOMAIN;
    root $SITE_DIR/static;
    index index.html;
    location ~ ^/(chat|chat/confirm) { allow 127.0.0.1; allow ::1; deny all; }
    location ~ ^/(health|build|setup|ask|agent|agents|analytics) {
        proxy_pass http://127.0.0.1:$PORT;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_read_timeout 120s;
    }
    location / { try_files \$uri \$uri/ \$uri/index.html @bridge; }
    location @bridge {
        proxy_pass http://127.0.0.1:$PORT;
        proxy_set_header Host \$host;
        proxy_read_timeout 120s;
    }
}
NGEOF
    nginx -t && systemctl reload nginx \
      && echo -e "\n  ${GREEN}✓${RESET} $DOMAIN now routes to $SITE_NAME" \
      || echo -e "\n  ${RED}!${RESET} nginx config error"
    IP=$(curl -s --max-time 3 ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}')
    echo -e "  ${DIM}  point your DNS A record → $IP${RESET}"
    echo -e "  ${DIM}  then: certbot --nginx -d $DOMAIN -d www.$DOMAIN${RESET}"
    echo ""
    ;;

  *)
    banner
    echo -e "  ${BOLD}commands:${RESET}\n"
    echo -e "  ${ACCENT}hermes studio${RESET}                    open chat + shell side by side (recommended)"
    echo -e "  ${ACCENT}hermes studio <name>${RESET}            same, for a specific vessel"
    echo -e "  ${ACCENT}hermes chat${RESET}                     open the operator terminal (inline)"
    echo -e "  ${ACCENT}hermes chat <name>${RESET}              open terminal for a specific vessel"
    echo -e "  ${ACCENT}hermes sites${RESET}                    list all vessels on this server"
    echo -e "  ${ACCENT}hermes new${RESET}                      rebuild this vessel from scratch"
    echo -e "  ${ACCENT}hermes new-site <name>${RESET}          create a new vessel (runs wizard)"
    echo -e "  ${ACCENT}hermes new-site <name> <domain>${RESET} same, with domain routing"
    echo -e "  ${ACCENT}hermes add-domain <name> <domain>${RESET}attach a domain to an existing site"
    echo -e "  ${ACCENT}hermes theme${RESET}                    show current terminal theme"
    echo -e "  ${ACCENT}hermes theme-reset${RESET}              reset to default style"
    echo -e "  ${ACCENT}hermes status [name]${RESET}            service status"
    echo -e "  ${ACCENT}hermes logs [name]${RESET}              live log stream"
    echo -e "  ${ACCENT}hermes build${RESET}                    rebuild the static site"
    echo -e "  ${ACCENT}hermes restart${RESET}                  restart the bridge"
    echo ""
    ;;

esac
