# HERMES WEBKIT — environment configuration
# Copy to .env and fill in your values.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: anthropic | ollama | openai
# anthropic: best quality, requires API key, ~$5-20/month
# ollama:    free, runs locally on your server, no API key needed
# openai:    requires API key
LLM_PROVIDER=anthropic

# ── Anthropic (if LLM_PROVIDER=anthropic) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── OpenAI (if LLM_PROVIDER=openai) ──────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Ollama (if LLM_PROVIDER=ollama) ──────────────────────────────────────────
# Ollama runs locally — install with: curl -fsSL https://ollama.ai/install.sh | sh
# OLLAMA_BASE_URL=http://localhost:11434/v1   # default, change if remote
# HERMES_MODEL=llama3.2                       # render model (use llama3.1 or qwen2.5-coder for operator tools)
# HERMES_MODEL_HECATE=llama3.2               # classifier model

# ── Model overrides (optional — defaults set per provider) ───────────────────
# HERMES_MODEL=claude-sonnet-4-6             # render/operator model
# HERMES_MODEL_HECATE=claude-haiku-4-5-20251001  # HECATE classifier
# HERMES_MAX_TOKENS=8192

# ── Security ─────────────────────────────────────────────────────────────────
# Required — protects /build, /setup, /analytics endpoints
BUILD_TOKEN=change-this-to-a-strong-random-secret

# ── Optional features ─────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_IDS=
# VISITOR_LIMIT_REDIRECT=https://github.com/psiloceyeben/HERMES-WebKit
