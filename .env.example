# HERMES WEBKIT — environment configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is never committed to git — your key stays on your server.
# ─────────────────────────────────────────────────────────────────────────────


# ── Required ──────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=your-key-here


# ── Model selection (optional) ────────────────────────────────────────────────

# Render model — produces the final HTML. Runs once per build.
# Default: claude-sonnet-4-6
# HERMES_MODEL=claude-sonnet-4-6

# Classification model — HECATE path routing. Fast and cheap.
# Default: claude-haiku-4-5-20251001
# HERMES_MODEL_HECATE=claude-haiku-4-5-20251001

# Max tokens for render output.
# Default: 4096
# HERMES_MAX_TOKENS=4096


# ── Server (optional) ─────────────────────────────────────────────────────────

# Port the bridge listens on. nginx proxies from 80 to this.
# Default: 8000
# PORT=8000


# ── Vessel directory (optional) ───────────────────────────────────────────────

# Path to the vessel directory.
# Useful when running multiple vessels on one server.
# Default: ./vessel
# VESSEL_DIR=/root/hermes/vessel


# ── Telegram (optional) ───────────────────────────────────────────────────────

# Token from @BotFather. Enables mobile editing via Telegram.
# Configure full details in channels/TELEGRAM.md
# TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to send operator commands.
# TELEGRAM_ALLOWED_IDS=
