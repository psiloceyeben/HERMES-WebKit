# ─────────────────────────────────────────────────────────────
# HERMES WEBKIT — environment variables
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Required — your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — model overrides
# HERMES_MODEL=claude-sonnet-4-6
# HERMES_MODEL_HECATE=claude-haiku-4-5-20251001
# HERMES_MODEL_AGENT=claude-sonnet-4-6
# HERMES_MAX_TOKENS=4096

# Optional — server
# PORT=8000
# VESSEL_DIR=/root/hermes/vessel
# STATIC_DIR=/root/hermes/static

# Optional — build protection (generate with: openssl rand -hex 32)
# BUILD_TOKEN=

# Optional — Telegram channel
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_IDS=123456789,987654321
