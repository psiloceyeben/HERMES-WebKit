# ─────────────────────────────────────────────────────────────
# HERMES WEBKIT — .gitignore
# ─────────────────────────────────────────────────────────────

# Environment — never commit API keys
.env

# Vessel identity — user-specific, generated by wizard
vessel/VESSEL.md
vessel/STATE.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Papers — research docs, not part of the runtime
paper*.md
paper*.pdf

# Local scratch
memory.md
patch_setup.py
test_routing.py

# Claude Code config
.claude/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Personal website — not part of the framework
static/index.html
static/landing.html
static/parchment.html
static/*.html

# Patch scripts — one-time migration, not part of framework
patch_*.py
fix_*.py
sec_patch*.py
add_vault.py
ollama_patch.py
scaffold_pantheon.sh
setup_subdomains.sh
write_nodes.sh

# Runtime data — user-specific
vessel/vault/
vessel/analytics.json
vessel/chat_history.json
vessel/generated/
vessel/habits.json
vessel/TASKS.md
vessels/

# Temp/backup
*.bak
*.pre-vault
.last_route
.hermes_status.sh
.hermes_theme.json
.hermes_tmux.conf
wizard.py
