# ─────────────────────────────────────────────────────────────
# HERMES WEBKIT — .gitignore
# ─────────────────────────────────────────────────────────────

# Environment — never commit API keys
.env

# Vessel identity — user-specific, generated by wizard
vessel/VESSEL.md
vessel/STATE.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Papers — research docs, not part of the runtime
paper*.md
paper*.pdf

# Local scratch
memory.md
patch_setup.py
test_routing.py

# Claude Code config
.claude/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
